#B)	Desarrolle un programa que permita ingresar la estatura y peso de una persona, debe 
# dividir el peso por la altura al cuadrado, el resultado debe desplegarlo como su IMC.

#Variable

estatura = 0.0
peso = 0.0
imc = 0.0

#Entrada

estatura = float(input("Ingrese su estatura: "))
peso = float(input("Ingrese su peso: "))

imc = peso / ( estatura * estatura)

#Salida

print("Su IMC es de ",imc,".")
